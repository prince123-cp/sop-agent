# Server Configuration
PORT=5000

# Database Configuration
# For local development:
# MONGODB_URI=mongodb://localhost:27017/adminchunk

# For MongoDB Atlas (production on Render):
# Get this from: MongoDB Atlas → Cluster → Connect → Drivers
# Format: mongodb+srv://username:password@cluster.mongodb.net/sopagent
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sopagent

# API Keys
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here
